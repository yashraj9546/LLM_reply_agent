generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 0. AUTH & STORE INSTALLATION
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // Relations
  stores    Store[]
}

model Store {
  id          Int      @id @default(autoincrement())
  shop        String   @unique
  accessToken String
  userId      String
  installedAt DateTime @default(now())

  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 1. IDENTITY & STORE MANAGEMENT
model Merchant {
  id                   Int           @id @default(autoincrement())
  storeName            String
  shopifyDomain        String        @unique
  shopifyAccessToken   String?
  whatsappBusinessId   String?
  phoneNumberId        String?
  createdAt            DateTime      @default(now())
  
  // Relations
  products             Product[]
  discounts            Discount[]
  userSessions         UserSession[]
}

model Customer {
  id          Int           @id @default(autoincrement())
  phoneNumber String        @unique // Format: '919876543210'
  name        String?
  createdAt   DateTime      @default(now())
  
  // Relations
  userSessions UserSession[]
}

// 2. INVENTORY (Knowledge Base)
model Product {
  id          Int              @id @default(autoincrement())
  merchantId  Int
  title       String
  description String?
  category    String?
  createdAt   DateTime         @default(now())
  
  // Relations
  merchant    Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  variants    ProductVariant[]
}

model ProductVariant {
  id               Int            @id @default(autoincrement())
  productId        Int
  sku              String         @unique
  color            String?
  size             String?
  price            Decimal        @db.Decimal(10, 2)
  currentStock     Int            @default(0)
  pineconeVectorId String?
  imageUrl         String?
  
  // Relations
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLogs    InventoryLog[]
}

// 3. LOGGING & COUNTS
model InventoryLog {
  id           Int            @id @default(autoincrement())
  variantId    Int
  changeAmount Int            // Positive for restock, negative for sale
  reason       String?        // 'whatsapp_sale', 'shopify_sync', etc.
  createdAt    DateTime       @default(now())
  
  // Relations
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// 4. MARKETING
model Discount {
  id           Int          @id @default(autoincrement())
  merchantId   Int
  code         String
  discountType DiscountType @default(PERCENTAGE)
  value        Decimal      @db.Decimal(10, 2)
  isActive     Boolean      @default(true)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime     @default(now())
  
  // Relations
  merchant     Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// 5. INTERACTION & MEMORY
model UserSession {
  id              Int           @id @default(autoincrement())
  customerId      Int
  merchantId      Int
  currentCartJson Json          @default("[]")
  sessionStatus   String        @default("active") // 'active', 'abandoned', 'converted'
  lastMessageAt   DateTime      @default(now())
  
  // Relations
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  merchant        Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  chatHistory     ChatHistory[]

  @@unique([customerId, merchantId]) // One active session per user per store
}

model ChatHistory {
  id        Int         @id @default(autoincrement())
  sessionId Int
  sender    SenderRole
  message   String      @db.Text
  createdAt DateTime    @default(now())
  
  // Relations
  session   UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

enum SenderRole {
  USER
  AGENT
}